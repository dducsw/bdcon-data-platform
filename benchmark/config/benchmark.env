# =============================================================================
# TPC-DS Benchmark Configuration
# Shared by both Spark and Trino jobs — keep resource budgets symmetric.
# =============================================================================

# ---------------------------------------------------------------------------
# Trino connection
# ---------------------------------------------------------------------------
TRINO_BASE_URL=http://localhost:8080
TRINO_USER=benchmark
TRINO_SOURCE=tpcds-benchmark
TRINO_CATALOG=iceberg_hive
TRINO_SCHEMA=benchmark_tpcds_sf5

# ---------------------------------------------------------------------------
# Spark connection (Thrift Server removed; Spark runs as in-process SparkSession
# inside the benchmark Job pod itself — no external server needed)
# ---------------------------------------------------------------------------
SPARK_CATALOG=iceberg_hive
SPARK_SCHEMA=benchmark_tpcds_sf5

# Iceberg / MinIO
ICEBERG_URI=thrift://hive-metastore:9083
ICEBERG_WAREHOUSE=s3a://iceberg/lakehouse
MINIO_ENDPOINT=http://minio:9000

# ---------------------------------------------------------------------------
# TPC-DS source (for prepare step)
# ---------------------------------------------------------------------------
TPCDS_SOURCE_CATALOG=tpcds
TPCDS_SOURCE_SCHEMA=sf5

# ---------------------------------------------------------------------------
# Benchmark parameters — IDENTICAL for both engines
# ---------------------------------------------------------------------------
QUERY_LIST=benchmark/queries/tpcds/query_list.txt
WARMUP_RUNS=1
RUNS=3
QUERY_TIMEOUT_SECONDS=1800
WRAP_COUNT=false

# ---------------------------------------------------------------------------
# Resource budget — mirrored in the Job manifests (keep in sync!)
# Each engine gets exactly 4 vCPU + 8 Gi memory.
# Spark: driver 4 vCPU / 8 Gi, local[4] (single pod, no separate executors)
# Trino: coordinator 1 vCPU / 2 Gi + 1 worker 3 vCPU / 6 Gi = 4 vCPU / 8 Gi
# ---------------------------------------------------------------------------
SPARK_DRIVER_CORES=4
SPARK_DRIVER_MEMORY=7g         # leave ~1 Gi for OS/container overhead

# ---------------------------------------------------------------------------
# Output
# ---------------------------------------------------------------------------
RESULTS_DIR=benchmark/results